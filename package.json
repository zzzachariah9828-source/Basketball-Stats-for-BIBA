{
  "name": "basketball-stats-scoreboard",
  "version": "1.0.0",
  "description": "Desktop basketball scoreboard and stats tracker",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.biba.scoreboard",
    "productName": "Basketball Scoreboard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "assets/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "identity": "-"
    },
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12"
  }
}
